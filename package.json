{
  "name": "peruvigia",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vp run --filter \"./apps/*\" dev",
    "dev:web": "vp run --filter @peruvigia/web dev",
    "dev:api": "vp run --filter @peruvigia/api dev",
    "build": "vp run -r build",
    "check": "vp run -r check",
    "test:api": "vp run --filter @peruvigia/api test",
    "start:api": "vp run --filter @peruvigia/api start",
    "db:check": "vp run --filter @peruvigia/api db:check",
    "db:generate": "vp run --filter @peruvigia/api db:generate",
    "db:migrate": "vp run --filter @peruvigia/api db:migrate",
    "db:studio": "vp run --filter @peruvigia/api db:studio",
    "sync:contraloria": "vp run --filter @peruvigia/api sync:contraloria",
    "sync:dji": "vp run --filter @peruvigia/api sync:dji"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.14"
  },
  "packageManager": "pnpm@10.16.1"
}
