{
  "name": "@peruvigia/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#api/*": "./src/*"
  },
  "scripts": {
    "dev": "vp exec tsx watch src/server.ts",
    "start": "node dist/server.mjs",
    "build": "vp pack",
    "check": "vp check package.json tsconfig.json src",
    "test": "vp test",
    "db:check": "vp exec tsx src/scripts/check-db.ts",
    "db:generate": "vp exec drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "vp exec tsx src/scripts/migrate-db.ts",
    "db:studio": "vp exec drizzle-kit studio --config=drizzle.config.ts",
    "sync:contraloria": "vp exec tsx src/scripts/sync-contraloria.ts",
    "sync:dji": "vp exec tsx src/scripts/sync-dji.ts",
    "sync:seace": "vp exec tsx src/scripts/sync-seace.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.2",
    "@peruvigia/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.6.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
